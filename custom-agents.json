{
    "mcp": {
        "systemFile": {
            "type": "local",
            "command": [
                "/home/joelrd01/.nvm/versions/node/v22.21.0/bin/npx",
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/home/joelrd01/"
            ],
            "enabled": true
        },
        "cli_MCP": {
            "type": "local",
            "command": [
                "uvx",
                "cli-mcp-server"
            ],
            "environment": {
                "ALLOWED_DIR": "/home/joelrd01/",
                "ALLOWED_COMMANDS": "ls,cat,pwd,echo,mkdir,rm,cp,mv,find,grep,tree,wc",
                "ALLOWED_FLAGS": "-l,-a,--help,--version,-r,-f,-p,-n,-i,-L,-I",
                "MAX_COMMAND_LENGTH": "2048",
                "COMMAND_TIMEOUT": "60",
                "ALLOW_SHELL_OPERATORS": "false"
            },
            "enabled": false
        },
        "npmAnalyzer": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@nekzus/mcp-server"
            ],
            "enabled": true
        },
        "pencil": {
            "command": [
                "/home/joelrd01/.antigravity/extensions/highagency.pencildev-0.6.29-universal/out/mcp-server-linux-x64",
                "--app",
                "antigravity"
            ],
            "enabled": true,
            "type": "local"
        }
    },
    "agent": {
        "orchestrator": {
            "mode": "primary",
            "prompt": "{file:./prompt-agent/orquestrator.md}",
            "readonly": {
                "tools": {
                    "*": "deny"
                }
            },
            "permission": {
                "edit": "deny",
                "task": {
                    "*": "deny",
                    "backend": "allow"
                }
            },
            "tools": {
                "*": false
            }
        },
        "backend": {
            "mode": "subagent",
            "prompt": "{file:./prompt-agent/backend.md}",
            "hidden": true,
            "readonly": {
                "tools": {
                    "*": "deny"
                }
            },
            "permission": {
                "task": {
                    "*": "deny",
                    "write-code": "allow",
                    "write-test": "allow",
                    "write-doc": "allow",
                    "extend-project": "allow"
                },
                "bash": {
                    "*": "deny",
                    "find": "allow",
                    "grep": "allow",
                    "locate": "allow",
                    "which": "allow",
                    "cat": "allow",
                    "less": "allow",
                    "head": "allow",
                    "tail": "allow",
                    "strings": "allow",
                    "ls": "allow",
                    "stat": "allow",
                    "file": "allow",
                    "du": "allow",
                    "pwd": "allow",
                    "realpath": "allow",
                    "info": "allow"
                }
            },
            "tools": {
                "*": false,
                "read": true,
                "bash": true
            }
        },
        "write-code": {
            "mode": "subagent",
            "hidden": true,
            "prompt": "{file:./prompt-agent/write-code.md}",
            "readonly": {
                "tools": {
                    "*": "ask"
                }
            },
            "permission": {
                "task": {
                    "*": "deny",
                    "write-test": "allow",
                    "write-doc": "allow",
                    "extend-project": "allow"
                },
                "bash": {
                    "*": "ask"
                }
            },
            "tools": {
                "*": true
            }
        },
        "write-test": {
            "mode": "subagent",
            "hidden": true,
            "prompt": "{file:./prompt-agent/write-test.md}",
            "readonly": {
                "tools": {
                    "*": "ask"
                }
            },
            "permission": {
                "task": {
                    "*": "deny",
                    "write-code": "allow",
                    "extend-project": "allow"
                },
                "bash": {
                    "*": "ask"
                }
            },
            "tools": {
                "*": true
            }
        },
        "write-doc": {
            "mode": "subagent",
            "hidden": true,
            "prompt": "{file:./prompt-agent/write-doc.md}",
            "readonly": {
                "tools": {
                    "*": "ask"
                }
            },
            "permission": {
                "task": {
                    "*": "deny",
                    "extend-project": "allow"
                },
                "bash": {
                    "*": "ask"
                }
            },
            "tools": {
                "*": true
            }
        },
        "extend-project": {
            "mode": "subagent",
            "hidden": true,
            "prompt": "{file:./prompt-agent/extend-project.md}",
            "readonly": {
                "tools": {
                    "*": "ask"
                }
            },
            "permission": {
                "task": {
                    "*": "deny",
                    "write-code": "allow",
                    "write-test": "allow",
                    "write-doc": "allow"
                },
                "bash": {
                    "*": "ask"
                }
            },
            "tools": {
                "*": true
            }
        }
    }
}